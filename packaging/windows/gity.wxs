<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi">
    <Product Id="*"
             Name="Gity"
             Language="1033"
             Version="0.1.0"
             Manufacturer="Gity Contributors"
             UpgradeCode="PUT-GUID-HERE">

        <Package InstallerVersion="500"
                 Compressed="yes"
                 InstallScope="perMachine"
                 Description="Gity - Fast Git Helper Daemon"
                 Comments="Accelerates Git operations for large repositories" />

        <MajorUpgrade DowngradeErrorMessage="A newer version of Gity is already installed." />
        <MediaTemplate EmbedCab="yes" />

        <Feature Id="ProductFeature" Title="Gity" Level="1">
            <ComponentGroupRef Id="ProductComponents" />
            <ComponentRef Id="PathEnvVariable" />
        </Feature>

        <UIRef Id="WixUI_Minimal" />
        <WixVariable Id="WixUILicenseRtf" Value="LICENSE.rtf" />
    </Product>

    <Fragment>
        <Directory Id="TARGETDIR" Name="SourceDir">
            <Directory Id="ProgramFiles64Folder">
                <Directory Id="INSTALLFOLDER" Name="Gity" />
            </Directory>
        </Directory>
    </Fragment>

    <Fragment>
        <ComponentGroup Id="ProductComponents" Directory="INSTALLFOLDER">
            <Component Id="GityExecutable" Guid="PUT-GUID-HERE">
                <File Id="gity.exe"
                      Source="$(var.SourceDir)\gity.exe"
                      KeyPath="yes" />
            </Component>
        </ComponentGroup>

        <Component Id="PathEnvVariable" Directory="INSTALLFOLDER" Guid="PUT-GUID-HERE">
            <Environment Id="PATH"
                         Name="PATH"
                         Value="[INSTALLFOLDER]"
                         Permanent="no"
                         Part="last"
                         Action="set"
                         System="yes" />
        </Component>
    </Fragment>
</Wix>
