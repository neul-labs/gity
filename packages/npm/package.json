{
  "name": "gity-cli",
  "version": "0.1.2",
  "description": "Make large Git repositories feel instant — a lightweight cross-platform daemon that accelerates git status and maintenance via fsmonitor and file watching",
  "main": "lib/cli.js",
  "bin": {
    "gity": "lib/cli.js"
  },
  "scripts": {
    "install": "node lib/install.js"
  },
  "keywords": [
    "git",
    "git-acceleration",
    "git-performance",
    "fsmonitor",
    "version-control",
    "developer-tools",
    "cli",
    "daemon",
    "git-status",
    "monorepo",
    "repo-management",
    "file-watcher",
    "background-service",
    "git-maintenance"
  ],
  "author": "Dipankar Sarkar <me@dipankar.name>",
  "contributors": [
    {
      "name": "Neul Labs",
      "url": "https://neul.uk"
    }
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/neul-labs/gity.git"
  },
  "homepage": "https://github.com/neul-labs/gity",
  "bugs": {
    "url": "https://github.com/neul-labs/gity/issues"
  },
  "engines": {
    "node": ">=14.0.0"
  },
  "os": [
    "linux",
    "darwin",
    "win32"
  ],
  "cpu": [
    "x64",
    "arm64"
  ]
}
