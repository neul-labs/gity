<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2010/07/nuspec.xsd">
  <metadata>
    <id>gity</id>
    <version>0.1.0</version>
    <title>Gity - Git Repository Accelerator</title>
    <authors>Dipankar Sarkar</authors>
    <owners>Dipankar Sarkar</owners>
    <projectUrl>https://github.com/neul-labs/gity</projectUrl>
    <iconUrl>https://github.com/neul-labs/gity/raw/main/assets/logo.png</iconUrl>
    <copyright>2026 Neul Labs</copyright>
    <licenseUrl>https://github.com/neul-labs/gity/blob/main/LICENSE</licenseUrl>
    <requireLicenseAcceptance>false</requireLicenseAcceptance>
    <description>
      Gity accelerates Git operations by providing a background daemon that
      handles fsmonitor, prefetching, and maintenance tasks.

      Features:
      - Git fsmonitor integration for faster status commands
      - Background prefetch of remote refs
      - Automated maintenance scheduling
      - Cross-platform support (Linux, macOS, Windows)
      - Written in Rust for maximum performance
    </description>
    <summary>Make large Git repositories feel instant</summary>
    <tags>git git-automation fsmonitor version-control developer-tools cli daemon prefetch windows</tags>
    <releaseNotes>See https://github.com/neul-labs/gity/releases</releaseNotes>
  </metadata>
  <files>
    <file src="tools\**\*" target="tools" />
  </files>
</package>
